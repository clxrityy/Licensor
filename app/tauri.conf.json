{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Licensor",
  "version": "0.1.0",
  "identifier": "com.mjanglin.licensor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Licensor",
        "width": 1000,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'none'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self' tauri://"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "templates/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/clxrityy/licensor/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyMzMxQ0RBQzRDN0UyMEIKUldRTDRzZkUyaHd6d25TamtlODZxaG02YlphenNHSEwrMFhHc3dzMDJkbzREc2NLRGI1TEZycHAK"
    }
  }
}